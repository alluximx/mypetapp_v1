    "@types/lodash": "4.14.178",
    "@types/react-native": "^0.63.48",
    "@ui-kitten/metro-config": "5.0.0",
    "babel-jest": "^26.6.3",
    "babel-plugin-module-resolver": "^4.1.0",
    "eslint": "^6.5.1",
    "husky": "^4.3.8",
    "jest": "^24.9.0",
    "jetifier": "^1.6.6",
    "metro-react-native-babel-preset": "^0.66.2",
    "prettier": "^2.0.2",
    "react-test-renderer": "17.0.2",
    "rimraf": "^3.0.2",
    "tslint": "^6.1.3",
    "typescript": "^4.1.3"
  },
  "jest": {
    "preset": "react-native",
    "transformIgnorePatterns": []
  }
}
