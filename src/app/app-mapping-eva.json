{
  "strict": {
    "text-font-family": "Montserrat-Medium"
  },
  "components": {
    "TopNavigation": {
      "meta": {
        "variantGroups": {
          "alignment": {
            "center": {
              "default": true
            },
            "start": {
              "default": false
            }
          }
        }
      }
    },
    "StatusBar": {
      "meta": {
        "scope": "mobile",
        "parameters": {
          "barStyle": {
            "type": "string"
          },
          "backgroundColor": {
            "type": "string"
          }
        },
        "appearances": {
          "default": {
            "default": true
          }
        },
        "variantGroups": {},
        "states": {}
      },
      "appearances": {
        "default": {
          "mapping": {
            "barStyle": "dark-content",
            "backgroundColor": "background-basic-color-2"
          }
        }
      }
    },
    "SafeAreaLayout": {
      "meta": {
        "scope": "mobile",
        "parameters": {
          "backgroundColor": {
            "type": "string"
          }
        },
        "appearances": {
          "default": {
            "default": true
          }
        },
        "variantGroups": {
          "insets": {
            "top": {
              "default": false
            },
            "bottom": {
              "default": false
            }
          }
        },
        "states": {}
      },
      "appearances": {
        "default": {
          "mapping": {},
          "variantGroups": {
            "position": {
              "top": {
                "backgroundColor": "background-basic-color-2"
              },
              "bottom": {
                "backgroundColor": "background-basic-color-1"
              }
            }
          }
        }
      }
    },
    "Datepicker": {
      "meta": {},
      "appearances": {
        "default": {
          "mapping": {},
          "variantGroups": {
            "status": {
              "basic": {
                "backgroundColor": "#CFE2D5",
                "textColor": "text-basic-color",
                "iconTintColor": "#0a7029"
              }
            },
            "size": {
              "small": {
                "borderRadius": 10
              },
              "medium": {
                "borderRadius": 10
              },
              "large": {
                "minHeight": 56,
                "borderRadius": 10
              }
            }
          }
        }
      }
    },
    "Toggle": {
      "meta": {},
      "appearances": {
        "default": {
          "mapping": {
            "borderWidth": 1.5,
            "height": 31,
            "iconWidth": 0,
            "iconHeight": 0
          },
          "variantGroups": {
            "status": {
              "success": {
                "borderColor": "rgb(229,229,229)",
                "state": {
                  "disabled": {
                    "backgroundColor": "transparent"
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
